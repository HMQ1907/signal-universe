# --- Copy this file to ".env" and replace placeholders ---

# Supabase: Dashboard → Project Settings → API
# Project URL
SUPABASE_URL=https://xxxxxxxx.supabase.co
# anon / public key (legacy public config; server dùng service key bên dưới)
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9....
# service_role — BẢO MẬT, chỉ dùng trên server, không commit, không đưa lên client
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9....

# Resend (https://resend.com) — gửi email đăng ký / quên mật khẩu. Dev có thể để trống nếu chưa cần email.
RESEND_API_KEY=
EMAIL_FROM=noreply@signal-universe.io

# URL app (local hoặc domain thật)
SITE_URL=http://localhost:3000
TELEGRAM_SUPPORT_LINK=https://t.me/signal_universe

# Cloudflare R2 (lưu CCCD user)
# Dashboard → R2 → Manage R2 API Tokens → Create Token (Object Read & Write)
CLOUDFLARE_R2_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_R2_ACCESS_KEY_ID=your_r2_access_key_id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
CLOUDFLARE_R2_BUCKET_NAME=signal
# Public URL: R2 → bucket signal → Settings → Public Access → enable → copy URL
CLOUDFLARE_R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxx.r2.dev
